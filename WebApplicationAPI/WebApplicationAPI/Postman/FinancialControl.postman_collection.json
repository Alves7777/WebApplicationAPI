        {
          "name": "Test Multi-Tenancy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Teste automático de multi-tenancy",
                  "pm.test(\"Status code é 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Retorna apenas dados do usuário logado\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    ",
                  "    // Verifica se todos os cartőes pertencem ao userId correto",
                  "    var userId = pm.collectionVariables.get(\"userId\");",
                  "    jsonData.data.forEach(function(card) {",
                  "        pm.expect(card.userId).to.eql(userId);",
                  "    });",
                  "});",
                  "",
                  "console.log(\"? Multi-tenancy validado!\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
