@page "/users"
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject UserService UserService

<Shared.BackButton />

<h3>Usuários</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Novo Usuário</button>
    </div>

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@(editingUser != null ? "Editar Usuário" : "Novo Usuário")</h5>
                <EditForm Model="userRequest" OnValidSubmit="SaveUser">
                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <InputText class="form-control" @bind-Value="userRequest.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="userRequest.Email" type="email" />
                    </div>
                    <button type="submit" class="btn btn-success">Salvar</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancelar</button>
                </EditForm>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Açőes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick="() => EditUser(user)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">Deletar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<User> users = new();
    private CreateUserRequest userRequest = new();
    private User? editingUser;
    private bool loading = true;
    private bool showForm = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        loading = true;
        try
        {
            users = await UserService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar usuários: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateForm()
    {
        editingUser = null;
        userRequest = new CreateUserRequest();
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private void EditUser(User user)
    {
        editingUser = user;
        userRequest = new CreateUserRequest
        {
            Name = user.Name,
            Email = user.Email
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task SaveUser()
    {
        try
        {
            if (editingUser != null)
            {
                var updateRequest = new UpdateUserRequest
                {
                    Name = userRequest.Name,
                    Email = userRequest.Email
                };
                await UserService.UpdateAsync(editingUser.Id, updateRequest);
                successMessage = "Usuário atualizado com sucesso!";
            }
            else
            {
                await UserService.CreateAsync(userRequest);
                successMessage = "Usuário criado com sucesso!";
            }
            showForm = false;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar usuário: {ex.Message}";
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingUser = null;
    }

    private async Task DeleteUser(int id)
    {
        if (await UserService.DeleteAsync(id))
        {
            successMessage = "Usuário deletado com sucesso!";
            await LoadUsers();
        }
        else
        {
            errorMessage = "Erro ao deletar usuário.";
        }
    }
}
