@page "/expenses"
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject ExpenseService ExpenseService

<Shared.BackButton />

<h3>Despesas</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Nova Despesa</button>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Filtros</h5>
            <div class="row">
                <div class="col-md-2">
                    <label class="form-label">MÍs</label>
                    <InputNumber class="form-control" @bind-Value="filterMonth" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Ano</label>
                    <InputNumber class="form-control" @bind-Value="filterYear" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Categoria</label>
                    <InputText class="form-control" @bind-Value="filterCategory" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <InputText class="form-control" @bind-Value="filterStatus" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">MÈtodo</label>
                    <InputText class="form-control" @bind-Value="filterPaymentMethod" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-secondary" @onclick="LoadExpenses">Filtrar</button>
                </div>
            </div>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@(editingExpense != null ? "Editar Despesa" : "Nova Despesa")</h5>
                <EditForm Model="expenseRequest" OnValidSubmit="SaveExpense">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">DescriÁ„o</label>
                            <InputText class="form-control" @bind-Value="expenseRequest.Description" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Valor</label>
                            <InputNumber class="form-control" @bind-Value="expenseRequest.Amount" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">MÍs</label>
                            <InputNumber class="form-control" @bind-Value="expenseRequest.Month" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Ano</label>
                            <InputNumber class="form-control" @bind-Value="expenseRequest.Year" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Categoria</label>
                            <InputText class="form-control" @bind-Value="expenseRequest.Category" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Status</label>
                            <InputText class="form-control" @bind-Value="expenseRequest.Status" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">MÈtodo de Pagamento</label>
                            <InputText class="form-control" @bind-Value="expenseRequest.PaymentMethod" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success">Salvar</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancelar</button>
                </EditForm>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>DescriÁ„o</th>
                    <th>Valor</th>
                    <th>MÍs/Ano</th>
                    <th>Categoria</th>
                    <th>Status</th>
                    <th>MÈtodo</th>
                    <th>AÁıes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var expense in expenses)
                {
                    <tr>
                        <td>@expense.Id</td>
                        <td>@expense.Description</td>
                        <td>@expense.Amount.ToString("C")</td>
                        <td>@expense.Month/@expense.Year</td>
                        <td>@expense.Category</td>
                        <td>@expense.Status</td>
                        <td>@expense.PaymentMethod</td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick="() => EditExpense(expense)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteExpense(expense.Id)">Deletar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <strong>Total: @expenses.Sum(e => e.Amount).ToString("C")</strong>
    </div>
}

@code {
    private List<Expense> expenses = new();
    private CreateExpenseRequest expenseRequest = new();
    private Expense? editingExpense;
    private bool loading = true;
    private bool showForm = false;
    private string? errorMessage;
    private string? successMessage;

    private int? filterMonth;
    private int? filterYear = DateTime.Now.Year;
    private string? filterCategory;
    private string? filterStatus;
    private string? filterPaymentMethod;

    protected override async Task OnInitializedAsync()
    {
        await LoadExpenses();
    }

    private async Task LoadExpenses()
    {
        loading = true;
        try
        {
            expenses = await ExpenseService.GetAllAsync(filterMonth, filterYear, filterCategory, filterStatus, filterPaymentMethod);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar despesas: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateForm()
    {
        editingExpense = null;
        expenseRequest = new CreateExpenseRequest
        {
            Month = DateTime.Now.Month,
            Year = DateTime.Now.Year
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private void EditExpense(Expense expense)
    {
        editingExpense = expense;
        expenseRequest = new CreateExpenseRequest
        {
            Description = expense.Description,
            Amount = expense.Amount,
            Month = expense.Month,
            Year = expense.Year,
            Category = expense.Category,
            Status = expense.Status,
            PaymentMethod = expense.PaymentMethod
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task SaveExpense()
    {
        try
        {
            if (editingExpense != null)
            {
                var updateRequest = new UpdateExpenseRequest
                {
                    Description = expenseRequest.Description,
                    Amount = expenseRequest.Amount,
                    Month = expenseRequest.Month,
                    Year = expenseRequest.Year,
                    Category = expenseRequest.Category,
                    Status = expenseRequest.Status,
                    PaymentMethod = expenseRequest.PaymentMethod
                };
                await ExpenseService.UpdateAsync(editingExpense.Id, updateRequest);
                successMessage = "Despesa atualizada com sucesso!";
            }
            else
            {
                await ExpenseService.CreateAsync(expenseRequest);
                successMessage = "Despesa criada com sucesso!";
            }
            showForm = false;
            await LoadExpenses();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar despesa: {ex.Message}";
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingExpense = null;
    }

    private async Task DeleteExpense(int id)
    {
        if (await ExpenseService.DeleteAsync(id))
        {
            successMessage = "Despesa deletada com sucesso!";
            await LoadExpenses();
        }
        else
        {
            errorMessage = "Erro ao deletar despesa.";
        }
    }
}
