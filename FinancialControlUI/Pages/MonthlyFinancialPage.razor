@page "/monthly-financial"

<AuthorizeRoute>
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject MonthlyFinancialService MonthlyFinancialService

<Shared.BackButton />

<h3>Controle Mensal Financeiro</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Novo Controle Mensal</button>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Filtros</h5>
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Ano</label>
                    <InputNumber class="form-control" @bind-Value="filterYear" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Mês</label>
                    <InputNumber class="form-control" @bind-Value="filterMonth" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-secondary" @onclick="LoadMonthlyFinancials">Filtrar</button>
                    <button class="btn btn-outline-secondary ms-2" @onclick="ClearFilters">Limpar</button>
                </div>
            </div>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@(editingMonthly != null ? "Editar Controle Mensal" : "Novo Controle Mensal")</h5>
                <EditForm Model="monthlyRequest" OnValidSubmit="SaveMonthlyFinancial">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Ano *</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Year" disabled="@(editingMonthly != null)" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Mês *</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Month" min="1" max="12" disabled="@(editingMonthly != null)" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Dinheiro (Money)</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Money" step="0.01" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">RV (Renda Variável)</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.RV" step="0.01" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Débito (Debit)</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Debit" step="0.01" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Outros (Others)</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Others" step="0.01" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Reserva (Reserve)</label>
                            <InputNumber class="form-control" @bind-Value="monthlyRequest.Reserve" step="0.01" />
                        </div>
                    </div>
                    <div class="alert alert-info">
                        <strong>Informação:</strong><br />
                        • <strong>Salário Total</strong> = Money + RV<br />
                        • <strong>Despesas Total</strong> = Debit + Others + Reserve + (Despesas do Cartão)<br />
                        • <strong>Balanço</strong> = Salário Total - Despesas Total<br />
                        • <strong>Pode Gastar</strong> = Calculado automaticamente
                    </div>
                    <button type="submit" class="btn btn-success">Salvar</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancelar</button>
                </EditForm>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Mês/Ano</th>
                    <th>Money</th>
                    <th>RV</th>
                    <th>Débito</th>
                    <th>Outros</th>
                    <th>Reserva</th>
                    <th>Salário Total</th>
                    <th>Despesas Total</th>
                    <th>Balanço</th>
                    <th>Pode Gastar</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var monthly in monthlyFinancials)
                {
                    <tr>
                        <td>@monthly.Id</td>
                        <td><strong>@monthly.MonthName/@monthly.Year</strong></td>
                        <td>@monthly.Money.ToString("C")</td>
                        <td>@monthly.RV.ToString("C")</td>
                        <td>@monthly.Debit.ToString("C")</td>
                        <td>@monthly.Others.ToString("C")</td>
                        <td>@monthly.Reserve.ToString("C")</td>
                        <td><strong>@monthly.SalaryTotal.ToString("C")</strong></td>
                        <td><strong>@monthly.ExpensesTotal.ToString("C")</strong></td>
                        <td class="@(monthly.Balance >= 0 ? "text-success fw-bold" : "text-danger fw-bold")">
                            @monthly.Balance.ToString("C")
                        </td>
                        <td class="@(monthly.CanSpend >= 0 ? "text-success" : "text-danger")">
                            @monthly.CanSpend.ToString("C")
                        </td>
                        <td>
                            <button class="btn btn-sm btn-warning" @onclick="() => EditMonthlyFinancial(monthly)">Editar</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteMonthlyFinancial(monthly.Id)">Excluir</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!monthlyFinancials.Any())
    {
        <div class="alert alert-info">
            Nenhum controle mensal encontrado. Clique em "Novo Controle Mensal" para criar o primeiro.
        </div>
    }
}

@code {
    private List<MonthlyFinancial> monthlyFinancials = new();
    private CreateMonthlyFinancialRequest monthlyRequest = new();
    private MonthlyFinancial? editingMonthly;
    private bool loading = true;
    private bool showForm = false;
    private string? errorMessage;
    private string? successMessage;

    private int? filterYear = DateTime.Now.Year;
    private int? filterMonth;

    protected override async Task OnInitializedAsync()
    {
        await LoadMonthlyFinancials();
    }

    private async Task LoadMonthlyFinancials()
    {
        loading = true;
        errorMessage = null;
        try
        {
            monthlyFinancials = await MonthlyFinancialService.GetAllAsync(filterYear, filterMonth);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar controles mensais: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateForm()
    {
        editingMonthly = null;
        monthlyRequest = new CreateMonthlyFinancialRequest
        {
            Year = DateTime.Now.Year,
            Month = DateTime.Now.Month,
            Money = 0,
            RV = 0,
            Debit = 0,
            Others = 0,
            Reserve = 0
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private void EditMonthlyFinancial(MonthlyFinancial monthly)
    {
        editingMonthly = monthly;
        monthlyRequest = new CreateMonthlyFinancialRequest
        {
            Year = monthly.Year,
            Month = monthly.Month,
            Money = monthly.Money,
            RV = monthly.RV,
            Debit = monthly.Debit,
            Others = monthly.Others,
            Reserve = monthly.Reserve
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task SaveMonthlyFinancial()
    {
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingMonthly != null)
            {
                var updateRequest = new UpdateMonthlyFinancialRequest
                {
                    Year = monthlyRequest.Year,
                    Month = monthlyRequest.Month,
                    Money = monthlyRequest.Money,
                    RV = monthlyRequest.RV,
                    Debit = monthlyRequest.Debit,
                    Others = monthlyRequest.Others,
                    Reserve = monthlyRequest.Reserve
                };
                await MonthlyFinancialService.UpdateAsync(editingMonthly.Id, updateRequest);
                successMessage = "Controle mensal atualizado com sucesso!";
            }
            else
            {
                await MonthlyFinancialService.CreateAsync(monthlyRequest);
                successMessage = "Controle mensal criado com sucesso!";
            }
            showForm = false;
            await LoadMonthlyFinancials();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar controle mensal: {ex.Message}";
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingMonthly = null;
        errorMessage = null;
        successMessage = null;
    }

    private void ClearFilters()
    {
        filterYear = null;
        filterMonth = null;
    }

    private async Task DeleteMonthlyFinancial(int id)
    {
        errorMessage = null;
        successMessage = null;
        try
        {
            if (await MonthlyFinancialService.DeleteAsync(id))
            {
                successMessage = "Controle mensal deletado com sucesso!";
                await LoadMonthlyFinancials();
            }
            else
            {
                errorMessage = "Erro ao deletar controle mensal.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao deletar: {ex.Message}";
        }
    }
}
</AuthorizeRoute>

