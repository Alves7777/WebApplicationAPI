@page "/creditcard/{CardId:int}/installments"
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject CreditCardService CreditCardService

<Shared.BackButton />

<h3>?? Compras Parceladas</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Cartăo: @cardName</h5>
            <p class="text-muted">Visualize todas as compras parceladas ativas neste cartăo</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (installments.Any())
    {
        <div class="row mb-3">
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6>Total de Compras</h6>
                        <h3>@installments.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6>Valor Total</h6>
                        <h3>@installments.Sum(i => i.TotalAmount).ToString("C")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6>Parcela Mensal Média</h6>
                        <h3>@(installments.Any() ? installments.Average(i => i.InstallmentAmount).ToString("C") : "R$ 0,00")</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Descriçăo</th>
                        <th>Categoria</th>
                        <th>Valor Total</th>
                        <th>Parcelas</th>
                        <th>Valor/Parcela</th>
                        <th>Data da Compra</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in installments.OrderByDescending(i => i.PurchaseDate))
                    {
                        <tr>
                            <td>@item.Description</td>
                            <td>@item.CategoryName</td>
                            <td>@item.TotalAmount.ToString("C")</td>
                            <td>@item.Installments</td>
                            <td>@item.InstallmentAmount.ToString("C")</td>
                            <td>@item.PurchaseDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Finalizada</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nenhuma compra parcelada encontrada para este cartăo.
        </div>
    }
}

@code {
    [Parameter] public int CardId { get; set; }

    private List<InstallmentPurchase> installments = new();
    private string cardName = "";
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCard();
        await LoadInstallments();
    }

    private async Task LoadCard()
    {
        try
        {
            var card = await CreditCardService.GetCardByIdAsync(CardId);
            cardName = card?.Name ?? "Cartăo năo encontrado";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar cartăo: {ex.Message}";
        }
    }

    private async Task LoadInstallments()
    {
        loading = true;
        errorMessage = null;
        try
        {
            installments = await CreditCardService.GetInstallmentPurchasesAsync(CardId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar compras parceladas: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}
