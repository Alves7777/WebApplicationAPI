@page "/dashboard"
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject MonthlyFinancialService MonthlyFinancialService
@inject ExpenseService ExpenseService
@inject CategoryService CategoryService

<Shared.BackButton />

<h3>Dashboard Financeiro</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    @if (currentMonth != null)
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h5 style="color: white;" class="card-title">Despesas Total</h5>
                        <h2>@currentMonth.ExpensesTotal.ToString("C")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white @(currentMonth.Balance >= 0 ? "bg-success" : "bg-danger")">
                    <div class="card-body">
                        <h5 class="card-title">Balanço</h5>
                        <h2>@currentMonth.Balance.ToString("C")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h5 class="card-title">Disponível para Gastar</h5>
                        <h2>@currentMonth.CanSpend.ToString("C")</h2>
                    </div>
                </div>
            </div>
        </div>

        @if (currentMonth.ExpensesTotal == 0)
        {
            <div class="alert alert-info">
                <h5>Bem-vindo ao Dashboard!</h5>
                <p>Vocę ainda năo tem dados cadastrados. Comece adicionando:</p>
                <ul>
                    <li><a href="/monthly-financial">Controle Mensal</a> - Configure seu salário e despesas mensais</li>
                    <li><a href="/expenses">Despesas</a> - Registre suas despesas</li>
                    <li><a href="/categories">Categorias</a> - Crie categorias para organizar</li>
                </ul>
            </div>
        }
        else
        {
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="text-white">Total por Categoria</h5>
                        </div>
                        <div class="card-body">
                            @if (expensesByCategory != null && expensesByCategory.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Categoria</th>
                                                <th class="text-end">Valor</th>
                                                <th class="text-end">Qtd</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in expensesByCategory.OrderByDescending(x => x.Value))
                                            {
                                                <tr>
                                                    <td>@item.Key</td>
                                                    <td class="text-end">@item.Value.ToString("C")</td>
                                                    <td class="text-end">@expensesCategoryCount[item.Key]</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p>Nenhuma categoria encontrada.</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="text-white">Total por Status</h5>
                        </div>
                        <div class="card-body">
                            @if (expensesByStatus != null && expensesByStatus.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Status</th>
                                                <th class="text-end">Valor</th>
                                                <th class="text-end">Qtd</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in expensesByStatus.OrderByDescending(x => x.Value))
                                            {
                                                <tr>
                                                    <td>@item.Key</td>
                                                    <td class="text-end">@item.Value.ToString("C")</td>
                                                    <td class="text-end">@expensesStatusCount[item.Key]</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p>Nenhum status encontrado.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (currentMonth != null)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="text-white">Controle Mensal - @currentMonth.MonthName/@currentMonth.Year</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <strong>Dinheiro Disponível:</strong>
                        <p>@currentMonth.Money.ToString("C")</p>
                    </div>
                    <div class="col-md-3">
                        <strong>Salário Total:</strong>
                        <p>@currentMonth.SalaryTotal.ToString("C")</p>
                    </div>
                    <div class="col-md-3">
                        <strong>Despesas Total:</strong>
                        <p>@currentMonth.ExpensesTotal.ToString("C")</p>
                    </div>
                    <div class="col-md-3">
                        <strong>Pode Gastar:</strong>
                        <p>@currentMonth.CanSpend.ToString("C")</p>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (recentExpenses.Any())
    {
        <div class="card">
            <div class="card-header">
                <h5 class="text-white">Despesas Recentes</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Descriçăo</th>
                                <th>Valor</th>
                                <th>Categoria</th>
                                <th>Status</th>
                                <th>Data</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var expense in recentExpenses.Take(10))
                            {
                                <tr>
                                    <td>@expense.Description</td>
                                    <td>@expense.Amount.ToString("C")</td>
                                    <td>@expense.Category</td>
                                    <td>@expense.Status</td>
                                    <td>@expense.CreatedAt.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h5>Controle Mensal năo encontrado</h5>
            <p>Vocę precisa criar um controle mensal para o męs atual (@DateTime.Now.Month/@DateTime.Now.Year).</p>
            <a href="/monthly-financial" class="btn btn-primary">Criar Controle Mensal</a>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
}

@code {
    private MonthlyFinancial? currentMonth;
    private List<Expense> recentExpenses = new();
    private Dictionary<string, decimal> expensesByCategory = new();
    private Dictionary<string, int> expensesCategoryCount = new();
    private Dictionary<string, decimal> expensesByStatus = new();
    private Dictionary<string, int> expensesStatusCount = new();
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        loading = true;
        errorMessage = null;
        try
        {
            var currentMonthValue = DateTime.Now.Month;
            var currentYearValue = DateTime.Now.Year;

            Console.WriteLine($"=== Dashboard - Carregando dados de {currentMonthValue}/{currentYearValue} ===");

            // Busca controle mensal do męs atual
            currentMonth = await MonthlyFinancialService.GetCurrentMonthAsync();
            if (currentMonth != null)
            {
                Console.WriteLine($"Controle Mensal: {currentMonth.MonthName}/{currentMonth.Year}");
                Console.WriteLine($"  ExpensesTotal: {currentMonth.ExpensesTotal}");
                Console.WriteLine($"  Balance: {currentMonth.Balance}");
                Console.WriteLine($"  CanSpend: {currentMonth.CanSpend}");
            }
            else
            {
                Console.WriteLine("Nenhum controle mensal encontrado");
            }

            // Busca todas as despesas do męs atual
            recentExpenses = await ExpenseService.GetAllAsync(currentMonthValue, currentYearValue);
            Console.WriteLine($"Total de despesas: {recentExpenses.Count}");

            // Calcula totais por categoria
            expensesByCategory = recentExpenses
                .GroupBy(e => e.Category ?? "Sem Categoria")
                .ToDictionary(g => g.Key, g => g.Sum(e => e.Amount));

            expensesCategoryCount = recentExpenses
                .GroupBy(e => e.Category ?? "Sem Categoria")
                .ToDictionary(g => g.Key, g => g.Count());

            Console.WriteLine($"Categorias encontradas: {expensesByCategory.Count}");

            // Calcula totais por status
            expensesByStatus = recentExpenses
                .GroupBy(e => e.Status ?? "Sem Status")
                .ToDictionary(g => g.Key, g => g.Sum(e => e.Amount));

            expensesStatusCount = recentExpenses
                .GroupBy(e => e.Status ?? "Sem Status")
                .ToDictionary(g => g.Key, g => g.Count());

            Console.WriteLine($"Status encontrados: {expensesByStatus.Count}");
            Console.WriteLine("=== Dashboard carregado com sucesso ===");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar dados do dashboard: {ex.Message}";
            Console.WriteLine($"ERRO: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");
        }
        finally
        {
            loading = false;
        }
    }
}
