@page "/creditcards"

<AuthorizeRoute>
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject CreditCardService CreditCardService

<Shared.BackButton />

<h3>Cartőes de Crédito</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Novo Cartăo</button>
    </div>

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@(editingCard != null ? "Editar Cartăo" : "Novo Cartăo")</h5>
                <EditForm Model="cardRequest" OnValidSubmit="SaveCard">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nome</label>
                            <InputText class="form-control" @bind-Value="cardRequest.Name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Bandeira</label>
                            <InputText class="form-control" @bind-Value="cardRequest.Brand" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Limite</label>
                            <InputNumber class="form-control" @bind-Value="cardRequest.CardLimit" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Dia de Fechamento</label>
                            <InputNumber class="form-control" @bind-Value="cardRequest.ClosingDay" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Dia de Vencimento</label>
                            <InputNumber class="form-control" @bind-Value="cardRequest.DueDay" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success">Salvar</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancelar</button>
                </EditForm>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="row">
        @foreach (var card in cards)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@card.Name</h5>
                        <p class="card-text">
                            <strong>Bandeira:</strong> @card.Brand<br />
                            <strong>Limite:</strong> @card.CardLimit.ToString("C")<br />
                            <strong>Fechamento:</strong> Dia @card.ClosingDay<br />
                            <strong>Vencimento:</strong> Dia @card.DueDay<br />
                            <strong>Status:</strong> @(card.IsActive ? "Ativo" : "Inativo")
                        </p>
                        <div class="btn-group-vertical w-100 mb-2">
                            <a href="/creditcard/@card.Id/expenses" class="btn btn-sm btn-info">Despesas</a>
                            <a href="/creditcard/@card.Id/statement" class="btn btn-sm btn-success">Extrato</a>
                            <a href="/creditcard/@card.Id/installments" class="btn btn-sm btn-primary">Parcelamentos</a>
                        </div>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => EditCard(card)">Editar</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteCard(card.Id)">Deletar</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<CreditCard> cards = new();
    private CreateCreditCardRequest cardRequest = new();
    private CreditCard? editingCard;
    private bool loading = true;
    private bool showForm = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCards();
    }

    private async Task LoadCards()
    {
        loading = true;
        try
        {
            cards = await CreditCardService.GetAllCardsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar cartőes: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateForm()
    {
        editingCard = null;
        cardRequest = new CreateCreditCardRequest();
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private void EditCard(CreditCard card)
    {
        editingCard = card;
        cardRequest = new CreateCreditCardRequest
        {
            Name = card.Name,
            Brand = card.Brand,
            CardLimit = card.CardLimit,
            ClosingDay = card.ClosingDay,
            DueDay = card.DueDay
        };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task SaveCard()
    {
        try
        {
            if (editingCard != null)
            {
                var updateRequest = new UpdateCreditCardRequest
                {
                    Name = cardRequest.Name,
                    Brand = cardRequest.Brand,
                    CardLimit = cardRequest.CardLimit,
                    ClosingDay = cardRequest.ClosingDay,
                    DueDay = cardRequest.DueDay,
                    IsActive = editingCard.IsActive
                };
                await CreditCardService.UpdateCardAsync(editingCard.Id, updateRequest);
                successMessage = "Cartăo atualizado com sucesso!";
            }
            else
            {
                await CreditCardService.CreateCardAsync(cardRequest);
                successMessage = "Cartăo criado com sucesso!";
            }
            showForm = false;
            await LoadCards();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao salvar cartăo: {ex.Message}";
        }
    }

    private void CancelForm()
    {
        showForm = false;
        editingCard = null;
    }

    private async Task DeleteCard(int id)
    {
        if (await CreditCardService.DeleteCardAsync(id))
        {
            successMessage = "Cartăo deletado com sucesso!";
            await LoadCards();
        }
        else
        {
            errorMessage = "Erro ao deletar cartăo.";
        }
    }
}
</AuthorizeRoute>
