@page "/categories"

<AuthorizeRoute>
@using FinancialControlUI.Models
@using FinancialControlUI.Services
@inject CategoryService CategoryService

<Shared.BackButton />

<h3>Categorias</h3>

@if (loading)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">Nova Categoria</button>
    </div>

    @if (showForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Nova Categoria</h5>
                <EditForm Model="newCategory" OnValidSubmit="CreateCategory">
                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <InputText class="form-control" @bind-Value="newCategory.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descriçăo</label>
                        <InputTextArea class="form-control" @bind-Value="newCategory.Description" />
                    </div>
                    <div class="mb-3">
                        <label class="form-check-label">
                            <InputCheckbox class="form-check-input" @bind-Value="newCategory.IsActive" />
                            Ativa
                        </label>
                    </div>
                    <button type="submit" class="btn btn-success">Criar</button>
                    <button type="button" class="btn btn-secondary" @onclick="() => showForm = false">Cancelar</button>
                </EditForm>
            </div>
        </div>
    }

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (successMessage != null)
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Descriçăo</th>
                    <th>Ativa</th>
                    <th>Criada em</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in categories)
                {
                    <tr>
                        <td>@category.Id</td>
                        <td>@category.Name</td>
                        <td>@category.Description</td>
                        <td>@(category.IsActive ? "Sim" : "Năo")</td>
                        <td>@category.CreatedAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Category> categories = new();
    private CreateCategoryRequest newCategory = new();
    private bool loading = true;
    private bool showForm = false;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        loading = true;
        try
        {
            categories = await CategoryService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar categorias: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ShowCreateForm()
    {
        newCategory = new CreateCategoryRequest { IsActive = true };
        showForm = true;
        errorMessage = null;
        successMessage = null;
    }

    private async Task CreateCategory()
    {
        try
        {
            var result = await CategoryService.CreateAsync(newCategory);
            if (result != null)
            {
                successMessage = "Categoria criada com sucesso!";
                showForm = false;
                await LoadCategories();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao criar categoria: {ex.Message}";
        }
    }
}
</AuthorizeRoute>
