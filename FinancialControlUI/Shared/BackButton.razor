@inject NavigationManager Navigation
@inject IJSRuntime JS

<button class="btn btn-back mb-3" @onclick="GoBack" type="button" aria-label="Voltar">
    <span class="back-arrow">?</span> Voltar
</button>

@code {
    private async Task GoBack()
    {
        try
        {
            // Tenta usar history.back do navegador
            await JS.InvokeVoidAsync("eval", "window.history.back()");
        }
        catch (Exception)
        {
            // Fallback: volta para a home se history.back falhar
            Navigation.NavigateTo("/");
        }
    }
}
